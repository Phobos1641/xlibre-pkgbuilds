# Maintainer: artist for XLibre <artist4xlibre@proton.me>

pkgname=xlibre-video-intel-git
_pkgname=xf86-video-intel
pkgver=3.0.0.6
pkgrel=1
arch=(x86_64 aarch64)
url="https://github.com/X11Libre/xf86-video-intel"
license=('MIT')
install=$pkgname.install
pkgdesc="Libre fork of X.Org Intel i810/i830/i915/945G/G965+ video drivers"
depends=('mesa' 'libxvmc' 'pixman' 'xcb-util>=0.3.9'
         'libxcb' 'libxfixes' 'libxshmfence' 'libdrm' 'libxrender'
         'libx11' 'libxdamage' 'libxext' 'libpciaccess' 'glibc')
makedepends=('git' 'xlibre-xserver' 'xlibre-xserver-common' 'xlibre-xserver-devel' 'X-ABI-VIDEODRV_VERSION=28.0'
  'libxv' 'autoconf' 'automake' 'binutils' 'fakeroot' 'findutils'
  'gawk' 'gcc' 'gettext' 'gzip' 'libtool' 'm4' 'make' 'patch' 'pkgconf'
  # additional deps for intel-virtual-output
  'libxrandr' 'libxinerama' 'libxcursor' 'libxtst' 'libxss')
optdepends=('libxrandr: for intel-virtual-output'
            'libxinerama: for intel-virtual-output'
            'libxcursor: for intel-virtual-output'
            'libxtst: for intel-virtual-output'
            'libxss: for intel-virtual-output')
replaces=('xf86-video-intel-uxa' 'xf86-video-intel-sna')
provides=('xlibre-video-intel' "xlibre-${_pkgname}" ${_pkgname} 'xf86-video-intel-uxa' 'xf86-video-intel-sna')
conflicts=('xlibre-video-intel' "xlibre-${_pkgname}" ${_pkgname} 'xorg-server<21.1.1' 'X-ABI-VIDEODRV_VERSION<28' 'X-ABI-VIDEODRV_VERSION>=29')
replaces=("xlibre-${_pkgname}" 'xf86-video-intel-sna' 'xf86-video-intel-uxa' 'xf86-video-i810' 'xf86-video-intel-legacy')
groups=('xlibre-drivers')
source=("${_pkgname}::git+https://github.com/X11Libre/xf86-video-intel.git#branch=master")
b2sums=('SKIP')
options=('!lto' '!debug' '!strip')

pkgver() (
  set -o pipefail

  cd "$_pkgname"
  git describe --long --tags 2>/dev/null \
    | sed -E 's/^xlibre-xf86-video-intel-//;s/([^-]*-g)/r\1/;s/-/./g' \
  || printf "r%s.%s" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short=7 HEAD)"
)

prepare() {
  cd xf86-video-intel
  NOCONFIGURE=1 ./autogen.sh
}

build() {
  case "$CARCH" in
    "x86_64")
      CFLAGS=" -march=corei7"
      ;;
    "aarch64")
      CFLAGS=" -march=armv8-a"
      ;;
    *)
      CFLAGS=" -march=native"
      ;;
  esac
  CFLAGS+=" -O2 -g -pipe -fexceptions -Wp,-D_FORTIFY_SOURCE=3 -Wformat -Werror=format-security"
  CFLAGS+=" -fstack-clash-protection -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer"
  LDFLAGS=" -Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,lazy -Wl,-z,relro -Wl,-z,pack-relative-relocs"
  if [[ $CARCH != 'aarch64' ]]; then
    CFLAGS+=" -fcf-protection"
  fi
  if [[ "$_pkgname" == *"xf86-input"* ]]; then
    CFLAGS+=" -fno-plt"
    LDFLAGS+=" -Wl,-z,now"
  fi
  if [[ "$_pkgname" == *"xf86-video-intel"* ]]; then
    CFLAGS+=" -fno-lto"
    LDFLAGS+=" -fno-lto"
  fi
  CXXFLAGS="${CFLAGS} -Wp,-D_GLIBCXX_ASSERTIONS"

  export CFLAGS="${CFLAGS}"
  export CXXFLAGS="${CXXFLAGS}"
  export LDFLAGS="${LDFLAGS}"

  cd xf86-video-intel
  ./configure --prefix=/usr \
    --libexecdir=/usr/lib \
    --with-default-dri=3
  sed -i -e 's/ -shared / -Wl,-O1,--as-needed\0/g' libtool
  make
}

check() {
  cd xf86-video-intel
  make check
}

package() {
  cd xf86-video-intel
  make DESTDIR="${pkgdir}" install

  install -Dm644 "${srcdir}"/xf86-video-intel/COPYING "${pkgdir}"/usr/share/licenses/${pkgname}/LICENSE
}
